# Execution mode: sim | live (default: sim)
MODE=sim

# Polymarket CLOB V2 credentials (required for live mode)
PRIVATE_KEY=
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
BUILDER_CODE=

# Optional: override chain (default: polygon)
CHAIN=polygon

# Discovery filters (comma-separated)
# Sport focus: nba, world_cup (default both; add more sports in sportsRegistry.ts later)
SPORT_FOCUS=nba,world_cup
TAG_IDS=
EVENT_SLUGS=
MAX_DISCOVERY_EVENTS=80

# Event-phase filtering: tracks upcoming (pre-game) AND live (in-progress)
# matches by default; only already-FINISHED games are excluded. Polymarket's
# active/closed flags don't reflect real game state (a finished match can
# stay "active" while awaiting settlement) — phase is derived from
# gameStartTime + a per-sport typical duration instead.
# Set TRACK_UPCOMING_ONLY=true for a stricter pre-game-only mode (also excludes live).
TRACK_UPCOMING_ONLY=false
MAX_LOOKAHEAD_HOURS=336
ALLOW_UNKNOWN_PHASE=true

# Risk limits
MAX_POSITION_USD=500
MAX_EVENT_EXPOSURE_USD=200
MIN_NET_EDGE_BPS=50
KELLY_FRACTION=0.5
MIN_STAKE_USD=100
DAILY_LOSS_LIMIT_USD=100
# Taker fee RATE in bps for Polymarket's fee curve: fee = shares x rate x p x (1-p).
# Sports category = 500 (rate 0.05, taker-only). NOT a flat percent of notional.
# Per-market rates from the API's feeSchedule override this default.
FEE_BPS=500
SLIPPAGE_BPS=10

# Simulation
SIM_INITIAL_BALANCE=10000

# Execution quality / risk extras
MAX_OPEN_ORDERS=20
MAX_BOOK_AGE_MS=15000
ORDER_PLACE_RETRIES=2
OPPORTUNITY_COOLDOWN_MS=5000
EXECUTED_COOLDOWN_MS=120000
TRADE_HISTORY_DIR=data/trades

# Logging
LOG_LEVEL=info
LOG_FILE=logs/bot.log
